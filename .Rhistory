library(tidyverse)
library(dplyr)
library(ggplot2)
proyectoInovacion = read_csv('proyectos_innovacion.csv')
paisesPib = read_csv('paises_pib.csv')
head(proyectoInovacion)
str(proyectoInovacion)
head(paisesPib)
str(paisesPib)
# Lista de países
listaPaises <- unique(proyectoInovacion$pais)
# Lista de áreas tecnológicas
listaAreas <- unique(proyectoInovacion$area_tecnologica)
estadisticasIniciales <- proyectoInovacion %>%
summarise(
proyectosTotales = sum(presupuesto_usd > 0),
presupuestoPromedio = mean(presupuesto_usd),
promedioPublicaciones = mean(publicaciones),
promedioInvestigadores = mean(investigadores)
)
proyectosPorArea <- split(proyectoInovacion, proyectoInovacion$area_tecnologica)
listaProyecto <- list( dataframeOriginal = proyectoInovacion, paises = listaPaises,
areasTecnologicas = listaAreas, estadisticas = estadisticasIniciales,
proyectosPorArea = proyectosPorArea
)
#uso de lapply
promerdiosAreaTecno <- lapply(proyectosPorArea, function(df) {
list(
proyectos = nrow(df),
presupuestoPromedio = mean(df$presupuesto_usd),
promedioPublicaciones = mean(df$publicaciones),
promedioInvestigadores = mean(df$investigadores)
)
})
listaIndicadores <- lapply(names(promerdiosAreaTecno), function(area) {
data.frame(
areaTecnologica = area,
numeroProyectos = promerdiosAreaTecno[[area]]$proyectos,
presupuestoPromedio = promerdiosAreaTecno[[area]]$presupuestoPromedio,
productividadPromedio = promerdiosAreaTecno[[area]]$promedioPublicaciones /
promerdiosAreaTecno[[area]]$promedioInvestigadores
)
})
# Unir todo en un solo dataframe
indicadoresAreaDf <- bind_rows(listaIndicadores)
# 1. Crear nuevas variables utilizando mutate
# Asumimos que el dataframe principal se llama 'proyectoInovacion' según tu código previo
proyectoInovacion <- proyectoInovacion %>%
mutate(
productividad = publicaciones / investigadores,
intensidad_investigacion = investigadores / duracion_meses,
indice_resultados = (publicaciones + 2 * patentes) / presupuesto_usd
)
# 2. Generar resúmenes utilizando group_by y summarize
# Presupuesto promedio por país y área tecnológica
presupuesto_pais_area <- proyectoInovacion %>%
group_by(pais, area_tecnologica) %>%
summarize(presupuesto_promedio = mean(presupuesto_usd, na.rm = TRUE), .groups = 'drop')
# Número de proyectos por año
# (Asegúrate que la columna se llame 'anio' o 'year' según tu CSV original)
proyectos_por_anio <- proyectoInovacion %>%
group_by(anio_inicio) %>%
summarize(total_proyectos = n(), .groups = 'drop')
# Productividad promedio por área tecnológica y nivel de impacto
productividad_area_impacto <- proyectoInovacion %>%
group_by(area_tecnologica, nivel_impacto) %>%
summarize(productividad_promedio = mean(productividad, na.rm = TRUE), .groups = 'drop')
library(tidyverse)
library(dplyr)
library(ggplot2)
proyectoInovacion = read_csv('proyectos_innovacion.csv')
paisesPib = read_csv('paises_pib.csv')
head(proyectoInovacion)
str(proyectoInovacion)
head(paisesPib)
str(paisesPib)
# Lista de países
listaPaises <- unique(proyectoInovacion$pais)
# Lista de áreas tecnológicas
listaAreas <- unique(proyectoInovacion$area_tecnologica)
estadisticasIniciales <- proyectoInovacion %>%
summarise(
proyectosTotales = sum(presupuesto_usd > 0),
presupuestoPromedio = mean(presupuesto_usd),
promedioPublicaciones = mean(publicaciones),
promedioInvestigadores = mean(investigadores)
)
proyectosPorArea <- split(proyectoInovacion, proyectoInovacion$area_tecnologica)
listaProyecto <- list( dataframeOriginal = proyectoInovacion, paises = listaPaises,
areasTecnologicas = listaAreas, estadisticas = estadisticasIniciales,
proyectosPorArea = proyectosPorArea
)
#uso de lapply
promerdiosAreaTecno <- lapply(proyectosPorArea, function(df) {
list(
proyectos = nrow(df),
presupuestoPromedio = mean(df$presupuesto_usd),
promedioPublicaciones = mean(df$publicaciones),
promedioInvestigadores = mean(df$investigadores)
)
})
listaIndicadores <- lapply(names(promerdiosAreaTecno), function(area) {
data.frame(
areaTecnologica = area,
numeroProyectos = promerdiosAreaTecno[[area]]$proyectos,
presupuestoPromedio = promerdiosAreaTecno[[area]]$presupuestoPromedio,
productividadPromedio = promerdiosAreaTecno[[area]]$promedioPublicaciones /
promerdiosAreaTecno[[area]]$promedioInvestigadores
)
})
# Unir todo en un solo dataframe
indicadoresAreaDf <- bind_rows(listaIndicadores)
# 1. Crear nuevas variables utilizando mutate
# Asumimos que el dataframe principal se llama 'proyectoInovacion' según tu código previo
proyectoInovacion <- proyectoInovacion %>%
mutate(
productividad = publicaciones / investigadores,
intensidad_investigacion = investigadores / duracion_meses,
indice_resultados = (publicaciones + 2 * patentes) / presupuesto_usd
)
# 2. Generar resúmenes utilizando group_by y summarize
# Presupuesto promedio por país y área tecnológica
presupuesto_pais_area <- proyectoInovacion %>%
group_by(pais, area_tecnologica) %>%
summarize(presupuesto_promedio = mean(presupuesto_usd, na.rm = TRUE), .groups = 'drop')
# Número de proyectos por año
# (Asegúrate que la columna se llame 'anio' o 'year' según tu CSV original)
proyectos_por_anio <- proyectoInovacion %>%
group_by(anio_inicio) %>%
summarize(total_proyectos = n(), .groups = 'drop')
# Productividad promedio por área tecnológica y nivel de impacto
productividad_area_impacto <- proyectoInovacion %>%
group_by(area_tecnologica, impacto) %>%
summarize(productividad_promedio = mean(productividad, na.rm = TRUE), .groups = 'drop')
# 3. Generar rankings utilizando arrange(desc(variable))
# Top 10 proyectos con mayor eficiencia
# (Utilizamos el indice_resultados como métrica de eficiencia según las fórmulas creadas)
top_10_eficiencia <- proyectoInovacion %>%
arrange(desc(indice_resultados)) %>%
head(10)
# Top 5 países con mayor productividad promedio
top_5_paises_productividad <- proyectoInovacion %>%
group_by(pais) %>%
summarize(prod_promedio_pais = mean(productividad, na.rm = TRUE)) %>%
arrange(desc(prod_promedio_pais)) %>%
head(5)
# Visualización opcional para verificar resultados
print(top_5_paises_productividad)
