# Visualizar el resul
# --- PARTE I: Manipulación de datos con dplyr
# 1. Cargar librerías
library(tidyverse)
# 2. Cargar el dataset
df <- read_csv("listings.csv")
# --- PARTE I: Manipulación de datos con dplyr ---
# Muestra las primeras filas y la estructura
head(df)
str(df)
df_limpio <- df %>%
# Limpieza de la columna price: quitar "$" y "," y convertir a numérico
mutate(price = as.numeric(gsub("[\\$,]", "", price))) %>%
# Filtrar: más de 10 reseñas, precio < 500 y host_location
filter(number_of_reviews > 10,
price < 500,
!is.na(host_location)) %>%
# Ordenar de mayor a menor disponibilidad
arrange(desc(availability_365)) %>%
# Crear columna total_revenue (ingreso potencial anual)
mutate(total_revenue = price * availability_365) %>%
# Seleccionar solo las columnas requeridas
select(host_location, room_type, price, availability_365, total_revenue, number_of_reviews)
# Visualizar el resultado final de la manipulación
view(df_limpio)
# --- PARTE II: Resúmenes y agrupaciones
# 1. Agrupar por ubicación del anfitrión y calcular métricas
resumen_ubicacion <- df_limpio %>%
group_by(host_location) %>%
summarize(
precio_promedio = mean(price, na.rm = TRUE),
total_alojamientos = n(),
ingreso_potencial_promedio = mean(total_revenue, na.rm = TRUE)
)
# 2. Agrupar por ubicación Y tipo de habitación
resumen_tipo_cuarto <- df_limpio %>%
group_by(host_location, room_type) %>%
summarize(
disponibilidad_promedio = mean(availability_365, na.rm = TRUE)
) %>%
ungroup()
# Visualizar los resúmenes
view(resumen_ubicacion)
view(resumen_tipo_cuarto)
library(tidyverse)
library(dplyr)
library(ggplot2)
proyectoInovacion = read_csv('proyectos_innovacion.csv')
paisesPib = read_csv('paises_pib.csv')
head(proyectoInovacion)
str(proyectoInovacion)
head(paisesPib)
str(paisesPib)
# Lista de países
listaPaises <- unique(proyectoInovacion$pais)
# Lista de áreas tecnológicas
listaAreas <- unique(proyectoInovacion$area_tecnologica)
estadisticasIniciales <- proyectoInovacion %>%
summarise(
proyectosTotales = sum(presupuesto_usd > 0),
presupuestoPromedio = mean(presupuesto_usd),
promedioPublicaciones = mean(publicaciones),
promedioInvestigadores = mean(investigadores)
)
proyectosPorArea <- split(proyectoInovacion, proyectoInovacion$area_tecnologica)
listaProyecto <- list( dataframeOriginal = proyectoInovacion, paises = listaPaises,
areasTecnologicas = listaAreas, estadisticas = estadisticasIniciales,
proyectosPorArea = proyectosPorArea
)
#uso de lapply
promerdiosAreaTecno <- lapply(proyectosPorArea, function(df) {
list(
proyectos = nrow(df),
presupuestoPromedio = mean(df$presupuesto_usd),
promedioPublicaciones = mean(df$publicaciones),
promedioInvestigadores = mean(df$investigadores)
)
})
listaIndicadores <- lapply(names(promerdiosAreaTecno), function(area) {
data.frame(
areaTecnologica = area,
numeroProyectos = promerdiosAreaTecno[[area]]$proyectos,
presupuestoPromedio = promerdiosAreaTecno[[area]]$presupuestoPromedio,
productividadPromedio = promerdiosAreaTecno[[area]]$promedioPublicaciones /
promerdiosAreaTecno[[area]]$promedioInvestigadores
)
})
# Unir todo en un solo dataframe
indicadoresAreaDf <- bind_rows(listaIndicadores)
setwd("~/proyecto_r-main")
